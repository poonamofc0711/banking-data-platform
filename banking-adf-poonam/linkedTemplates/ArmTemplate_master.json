{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "banking-adf-poonam"
		},
		"ls_adls_banking_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_adls_banking'"
		},
		"ls_adls_banking_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://bankingdatalakepn.dfs.core.windows.net/"
		},
		"ls_databricks_banking_properties_typeProperties_existingClusterId": {
			"type": "string",
			"defaultValue": "0430-221045-x0d6v2l3"
		},
		"ls_keyvault_banking_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://banking-kv-poonam.vault.azure.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "banking-adf-poonam_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_adls_banking_accountKey": {
						"value": "[parameters('ls_adls_banking_accountKey')]"
					},
					"ls_adls_banking_properties_typeProperties_url": {
						"value": "[parameters('ls_adls_banking_properties_typeProperties_url')]"
					},
					"ls_keyvault_banking_properties_typeProperties_baseUrl": {
						"value": "[parameters('ls_keyvault_banking_properties_typeProperties_baseUrl')]"
					},
					"ls_databricks_banking_properties_typeProperties_existingClusterId": {
						"value": "[parameters('ls_databricks_banking_properties_typeProperties_existingClusterId')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}